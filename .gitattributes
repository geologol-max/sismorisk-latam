# Normalizar saltos de línea automáticamente
# Los archivos de texto usan LF en el repo, CRLF en Windows
* text=auto

# Forzar LF en archivos de código/script
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf

# Binarios — no modificar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff2 binary
*.ttf   binary
